<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Настольный теннис HD</title>
<style>
html,body{
margin:0;
overflow:hidden;
background:#111;
font-family:Arial,sans-serif;
}
canvas{
display:block;
touch-action:none;
}
#menu{
position:absolute;
top:15px;
right:15px;
background:rgba(0,0,0,.7);
padding:10px;
border-radius:10px;
color:white;
z-index:10;
}
select{
padding:5px;
font-size:16px;
}
</style>
</head>
<body>

<div id="menu">
Сложность:
<select id="difficulty">
<option value="0.01">Безобидная</option>
<option value="0.04">Легкая</option>
<option value="0.07" selected>Средняя</option>
<option value="0.12">Сложная</option>
<option value="0.20">Эксперт</option>
<option value="0.35">Хакерская</option>
</select>
</div>

<canvas id="game"></canvas>

<script>

const canvas=document.getElementById("game");
const ctx=canvas.getContext("2d");

function resize(){
canvas.width=innerWidth;
canvas.height=innerHeight;
}
resize();
addEventListener("resize",resize);

const difficulty=document.getElementById("difficulty");

const score={
player:0,
bot:0
};

const player={
x:0,
y:0,
r:45
};

const bot={
x:0,
y:0,
r:45
};

const ball={
x:0,
y:0,
vx:0,
vy:0,
r:10
};

let serving=true;
let charging=false;
let power=0;
const maxPower=22;

function resetPositions(){

player.x=canvas.width/2;
player.y=canvas.height*0.82;

bot.x=canvas.width/2;
bot.y=canvas.height*0.18;

ball.x=player.x;
ball.y=player.y-70;

ball.vx=0;
ball.vy=0;

serving=true;
power=0;
}

resetPositions();

function movePlayer(x,y){

player.x=x;
player.y=y;

player.x=Math.max(80,Math.min(canvas.width-80,player.x));
player.y=Math.max(canvas.height/2+60,
Math.min(canvas.height-90,player.y));

if(serving){
ball.x=player.x;
ball.y=player.y-70;
}
}

canvas.addEventListener("mousemove",e=>{
movePlayer(e.clientX,e.clientY);
});

canvas.addEventListener("touchmove",e=>{
movePlayer(
e.touches[0].clientX,
e.touches[0].clientY
);
e.preventDefault();
});

canvas.addEventListener("mousedown",()=>{
charging=true;
});

canvas.addEventListener("mouseup",shoot);

canvas.addEventListener("touchstart",e=>{
charging=true;
e.preventDefault();
});

canvas.addEventListener("touchend",e=>{
shoot();
e.preventDefault();
});

function shoot(){

if(!charging)return;

charging=false;

if(serving){

ball.vx=(Math.random()*4)-2;
ball.vy=-(8+power*0.7);

serving=false;

}else{

const dx=ball.x-player.x;
const dy=ball.y-player.y;

const angle=Math.atan2(dy,dx);
const speed=12+power;

ball.vx=Math.cos(angle)*speed;
ball.vy=-Math.abs(Math.sin(angle)*speed);
}

power=0;
}

function hit(r){

const dx=ball.x-r.x;
const dy=ball.y-r.y;

const dist=Math.hypot(dx,dy);
const minDist=r.r+ball.r;

if(dist>0 && dist<minDist){

const nx=dx/dist;
const ny=dy/dist;

ball.x=r.x+nx*minDist;
ball.y=r.y+ny*minDist;

const botBoost=
difficulty.value=="0.35"
? 22
: difficulty.value=="0.20"
? 18
: difficulty.value=="0.12"
? 14
: 10;

const speed=(r===player)
? 12+power
: botBoost;

ball.vx=nx*speed;

if(r===player){
ball.vy=-Math.max(4,Math.abs(ny*speed));
}else{
ball.vy=Math.max(4,Math.abs(ny*speed));
}
}
}

function updateBot(){

const ai=parseFloat(difficulty.value);

bot.x+=(ball.x-bot.x)*ai;

if(ai>=0.20){
bot.y+=((ball.y-120)-bot.y)*0.10;
}else{
bot.y=canvas.height*0.18;
}

bot.x=Math.max(80,
Math.min(canvas.width-80,bot.x));

if(bot.y<80)bot.y=80;
if(bot.y>canvas.height/2-60)
bot.y=canvas.height/2-60;
}

function updatePower(){

if(charging){

power+=0.35;

if(power>maxPower)
power=maxPower;
}
}

let stuckFrames=0;

function updateBall(){

if(serving)return;

ball.x+=ball.vx;
ball.y+=ball.vy;

ball.vx*=0.998;
ball.vy*=0.998;

if(ball.x<60){
ball.x=60;
ball.vx*=-1;
}

if(ball.x>canvas.width-60){
ball.x=canvas.width-60;
ball.vx*=-1;
}

hit(player);
hit(bot);

if(Math.abs(ball.vx)<0.15 &&
Math.abs(ball.vy)<0.15){
stuckFrames++;
}else{
stuckFrames=0;
}

if(stuckFrames>60){
resetPositions();
return;
}

if(ball.y<0){

score.player++;

if(score.player>=11){

alert("Игрок победил!");

score.player=0;
score.bot=0;
}

resetPositions();
}

if(ball.y>canvas.height){

score.bot++;

if(score.bot>=11){

alert("Бот победил!");

score.player=0;
score.bot=0;
}

resetPositions();
}
}

function drawTable(){

const x=50;
const y=40;
const w=canvas.width-100;
const h=canvas.height-80;

const grad=ctx.createLinearGradient(
0,y,0,y+h
);

grad.addColorStop(0,"#2f8cff");
grad.addColorStop(1,"#0b4d9c");

ctx.fillStyle=grad;
ctx.fillRect(x,y,w,h);

ctx.strokeStyle="white";
ctx.lineWidth=5;
ctx.strokeRect(x,y,w,h);

ctx.beginPath();
ctx.moveTo(x,y+h/2);
ctx.lineTo(x+w,y+h/2);
ctx.stroke();

drawNet();
}

function drawNet(){

const y=canvas.height/2;

ctx.fillStyle="white";

for(let i=50;i<canvas.width-50;i+=8){
ctx.fillRect(i,y-18,3,36);
}
}

function drawRacket(x,y,color){

ctx.save();

ctx.translate(x,y);

ctx.fillStyle="#b8875c";
ctx.fillRect(-8,25,16,70);

ctx.beginPath();
ctx.arc(0,0,45,0,Math.PI*2);

ctx.fillStyle=color;
ctx.fill();

ctx.lineWidth=4;
ctx.strokeStyle="#111";
ctx.stroke();

ctx.restore();
}

function drawBall(){

ctx.beginPath();

ctx.arc(
ball.x,
ball.y,
ball.r,
0,
Math.PI*2
);

const g=ctx.createRadialGradient(
ball.x-3,
ball.y-3,
2,
ball.x,
ball.y,
ball.r
);

g.addColorStop(0,"#fff");
g.addColorStop(1,"orange");

ctx.fillStyle=g;
ctx.fill();
}

function drawPower(){

ctx.fillStyle="white";
ctx.font="20px Arial";

ctx.fillText("Сила",20,40);

ctx.strokeRect(20,50,220,20);

ctx.fillStyle="lime";

ctx.fillRect(
20,
50,
(power/maxPower)*220,
20
);
}

function drawScore(){

ctx.fillStyle="white";
ctx.font="40px Arial";

ctx.fillText(
score.bot,
canvas.width/2+40,
canvas.height/2-25
);

ctx.fillText(
score.player,
canvas.width/2-70,
canvas.height/2+55
);
}

function game(){

ctx.clearRect(
0,
0,
canvas.width,
canvas.height
);

updatePower();
updateBot();
updateBall();

drawTable();

drawRacket(
bot.x,
bot.y,
"#111"
);

drawRacket(
player.x,
player.y,
"#ff4040"
);

drawBall();
drawPower();
drawScore();

requestAnimationFrame(game);
}

game();

</script>
</body>
</html>
